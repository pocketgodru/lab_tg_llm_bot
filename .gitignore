*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
.ENV

# Virtual environment (PyCharm)
.venv/

# Virtual environment (virtualenvwrapper)
RENV/

# pip
pip-log.txt
pip-delete-this-directory.txt

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# =============================================================================
# ENVIRONMENT VARIABLES & SECRETS (ВАЖНО!)
# =============================================================================
# Никогда не коммитьте реальные ключи!
.env
.env.local
.env.*.local
*.env
*.env.local
*.env.production
*.env.development
*.env.test

# Ключи API и секреты (шаблоны можно коммитьте)
!*.env.example
!*.env.template
secrets/
*.key
*.pem
*.crt

